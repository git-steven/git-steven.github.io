<mxfile host="Electron" agent="Claude Code" version="28.2.8">
  <diagram name="Ports and Adapters (DIP)" id="lapt2ports">
    <mxGraphModel dx="960" dy="620" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="960" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title ===== -->
        <mxCell id="title" value="&lt;b&gt;&lt;font data-font-src=&quot;https://fonts.googleapis.com/css?family=Architects+Daughter&quot; face=&quot;Architects Daughter&quot;&gt;Ports &amp;amp; Adapters — Inverting the Dependency&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="180" y="20" width="600" height="36" as="geometry" />
        </mxCell>

        <!-- ===== Application Core container ===== -->
        <mxCell id="core" value="&lt;div style=&quot;font-family: Garamond; font-size: 13px; text-align: left;&quot;&gt;&lt;b&gt;&lt;font face=&quot;Architects Daughter&quot; style=&quot;font-size: 16px;&quot;&gt;Application Core&lt;/font&gt;&lt;/b&gt; &amp;nbsp;(Domain + Service) — &lt;i&gt;knows only the Protocol&lt;/i&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFBF2;strokeColor=#B09500;dashed=1;dashPattern=8 4;fontColor=#000000;align=left;verticalAlign=top;spacing=8;sketch=1;jiggle=1;curveFitting=1;arcSize=4;" parent="1" vertex="1">
          <mxGeometry x="120" y="100" width="720" height="150" as="geometry" />
        </mxCell>

        <!-- ===== Use case (depends on the port) ===== -->
        <mxCell id="usecase" value="&lt;b&gt;&lt;font face=&quot;Lucida Console&quot; style=&quot;font-size: 13px;&quot;&gt;PlaceOrderUseCase&lt;/font&gt;&lt;/b&gt;&lt;div style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;calls &lt;font face=&quot;Lucida Console&quot;&gt;repo.get(id)&lt;/font&gt;&lt;br&gt;through the abstraction&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;glass=1;fillColor=#FFFFCC;strokeColor=#D6B656;fontColor=#000000;sketch=1;jiggle=1;curveFitting=1;arcSize=10;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="160" y="150" width="230" height="78" as="geometry" />
        </mxCell>

        <!-- ===== Port (Protocol) ===== -->
        <mxCell id="port" value="&lt;b&gt;&lt;font face=&quot;Lucida Console&quot; style=&quot;font-size: 12px;&quot;&gt;«Protocol»&lt;br&gt;UserRepository&lt;/font&gt;&lt;/b&gt;&lt;div style=&quot;font-family: Garamond; font-size: 11px;&quot;&gt;the PORT (interface)&lt;/div&gt;" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontColor=#000000;sketch=1;jiggle=1;curveFitting=1;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="540" y="145" width="240" height="88" as="geometry" />
        </mxCell>

        <!-- usecase depends on port (uses the abstraction) -->
        <mxCell id="uses" value="&lt;font style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;depends on&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=open;endFill=0;strokeColor=#333333;strokeWidth=2;fontColor=#333333;sketch=1;jiggle=1;curved=1;" parent="1" source="usecase" target="port" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Composition Root ===== -->
        <mxCell id="comp" value="&lt;b&gt;&lt;font face=&quot;Architects Daughter&quot; style=&quot;font-size: 15px;&quot;&gt;Composition Root&lt;/font&gt;&lt;/b&gt;&lt;div style=&quot;font-family: Garamond; font-size: 12px; text-align: left;&quot;&gt;wires the concrete adapter via&lt;br&gt;&lt;font face=&quot;Lucida Console&quot;&gt;Depends(get_user_repo)&lt;/font&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;glass=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontColor=#000000;align=left;verticalAlign=top;spacing=8;sketch=1;jiggle=1;curveFitting=1;arcSize=10;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="360" width="250" height="110" as="geometry" />
        </mxCell>

        <!-- ===== Production adapter ===== -->
        <mxCell id="pg" value="&lt;b&gt;&lt;font face=&quot;Lucida Console&quot; style=&quot;font-size: 13px;&quot;&gt;PostgresUserRepo&lt;/font&gt;&lt;/b&gt;&lt;div style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;adapter — real SQL&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;glass=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#000000;sketch=1;jiggle=1;curveFitting=1;arcSize=10;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="430" y="380" width="220" height="74" as="geometry" />
        </mxCell>

        <!-- ===== Test adapter ===== -->
        <mxCell id="fake" value="&lt;b&gt;&lt;font face=&quot;Lucida Console&quot; style=&quot;font-size: 13px;&quot;&gt;FakeUserRepo&lt;/font&gt;&lt;/b&gt;&lt;div style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;adapter — in-memory (tests)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;glass=1;fillColor=#EEEEEE;strokeColor=#999999;fontColor=#000000;dashed=1;dashPattern=6 4;sketch=1;jiggle=1;curveFitting=1;arcSize=10;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="690" y="380" width="220" height="74" as="geometry" />
        </mxCell>

        <!-- production adapter implements port (points UP / inward) -->
        <mxCell id="impl1" value="&lt;font style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;implements ▲&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=0;entryX=0.4;entryY=1;endArrow=block;endFill=0;strokeColor=#82B366;strokeWidth=2.5;fontColor=#5A7D3C;sketch=1;jiggle=1;curved=1;" parent="1" source="pg" target="port" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- test adapter implements port (points UP / inward) -->
        <mxCell id="impl2" value="&lt;font style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;implements ▲&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=0;entryX=0.7;entryY=1;endArrow=block;endFill=0;strokeColor=#999999;strokeWidth=2;fontColor=#777777;dashed=1;sketch=1;jiggle=1;curved=1;" parent="1" source="fake" target="port" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- composition root injects concrete impl into the use case -->
        <mxCell id="inject" value="&lt;font style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;injects chosen adapter&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=0;entryX=0.3;entryY=1;endArrow=open;endFill=1;strokeColor=#6C8EBF;strokeWidth=2;fontColor=#3B5A8A;dashed=1;sketch=1;jiggle=1;curved=1;" parent="1" source="comp" target="usecase" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- composition root selects an adapter -->
        <mxCell id="select" value="&lt;font style=&quot;font-family: Garamond; font-size: 12px;&quot;&gt;selects&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=open;endFill=1;strokeColor=#6C8EBF;strokeWidth=2;fontColor=#3B5A8A;dashed=1;sketch=1;jiggle=1;curved=1;" parent="1" source="comp" target="pg" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== Caption ===== -->
        <mxCell id="caption" value="&lt;div style=&quot;font-family: Garamond; font-size: 13px;&quot;&gt;Adapters point &lt;b&gt;inward&lt;/b&gt; at the port (Dependency Inversion). The core depends on the &lt;b&gt;Protocol&lt;/b&gt;, never on an adapter — so you swap &lt;font face=&quot;Lucida Console&quot;&gt;PostgresUserRepo&lt;/font&gt; ↔ &lt;font face=&quot;Lucida Console&quot;&gt;FakeUserRepo&lt;/font&gt; with &lt;b&gt;zero change to the core.&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F8F8;strokeColor=#999999;fontColor=#000000;align=left;verticalAlign=middle;spacing=8;dashed=1;sketch=1;jiggle=1;curveFitting=1;arcSize=4;" parent="1" vertex="1">
          <mxGeometry x="120" y="500" width="790" height="56" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
